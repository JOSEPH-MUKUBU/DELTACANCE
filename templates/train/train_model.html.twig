{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<h1 class="mb-4"><i class="fas fa-brain"></i> {{ title }}</h1>

<div class="alert alert-info">
    <h6><i class="fas fa-info-circle"></i> Modèle: {{ model|replace({'_': ' '})|title }}</h6>
    <p><strong>Dataset:</strong> {{ dataset|replace({'_': ' '})|title }}</p>
</div>

{% if training %}
    <div class="row">
        <div class="col-md-6">
            <div class="stat-card text-white">
                <h5><i class="fas fa-chart-line"></i> Performances du modèle</h5>
                <hr style="border-color: rgba(255,255,255,0.3);">
                <p><strong>Accuracy:</strong> {{ (training.accuracy * 100)|number_format(2) }}%</p>
                <p><strong>Precision:</strong> {{ (training.precision * 100)|number_format(2) }}%</p>
                <p><strong>Recall:</strong> {{ (training.recall * 100)|number_format(2) }}%</p>
                <p><strong>F1-Score:</strong> {{ (training.f1_score * 100)|number_format(2) }}%</p>
                <p><strong>Temps d'entraînement:</strong> {{ training.training_time|number_format(2) }}s</p>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5><i class="fas fa-table"></i> Matrice de confusion</h5>
                </div>
                <div class="card-body">
                    {% if training.confusion_matrix %}
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm">
                                <thead>
                                    <tr>
                                        <th></th>
                                        {% for i in 0..(training.confusion_matrix[0]|length - 1) %}
                                        <th>Classe {{ i }}</th>
                                        {% endfor %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for i, row in training.confusion_matrix %}
                                    <tr>
                                        <th>Classe {{ i }}</th>
                                        {% for cell in row %}
                                        <td>{{ cell }}</td>
                                        {% endfor %}
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5><i class="fas fa-check-circle"></i> Modèle entraîné avec succès!</h5>
                </div>
                <div class="card-body">
                    <p>Le modèle a été sauvegardé et peut être utilisé pour des prédictions.</p>
                    <a href="{{ path('compare') }}" class="btn btn-primary">
                        <i class="fas fa-balance-scale"></i> Comparer avec d'autres modèles
                    </a>
                </div>
            </div>
        </div>
    </div>
{% else %}
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> Aucun résultat d'entraînement disponible. Veuillez lancer l'entraînement depuis la page principale.
    </div>
{% endif %}
{% endblock %}


