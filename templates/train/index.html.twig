{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% block breadcrumb %}Modeling & Training{% endblock %}

{% block body %}
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-md-2 text-center border-end">
                        <i class="fas fa-brain fa-4x mb-3 text-primary opacity-25"></i>
                    </div>
                    <div class="col-md-10 ps-4">
                        <h5 class="fw-bold mb-3">Model Training Pipeline</h5>
                        <p class="text-muted small mb-3">Trois modèles de familles différentes pour une classification optimisée.</p>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge rounded-pill bg-light text-primary border px-3 py-2"><i class="fas fa-tree me-1"></i> Random Forest</span>
                            <span class="badge rounded-pill bg-light text-primary border px-3 py-2"><i class="fas fa-project-diagram me-1"></i> SVM</span>
                            <span class="badge rounded-pill bg-light text-primary border px-3 py-2"><i class="fas fa-layer-group me-1"></i> Neural Network</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <span class="fw-bold"><i class="fas fa-layer-group me-2"></i> Initial Configuration</span>
                <span class="badge rounded-pill bg-light text-primary border px-3 py-1">Step 1</span>
            </div>
            <div class="card-body p-4">
                <div class="row">
                    <div class="col-md-6">
                        <label for="dataset-select" class="form-label fw-bold small text-muted">TARGET DATASET</label>
                        <select id="dataset-select" class="form-select border-0 bg-light rounded-3 py-2">
                            <option value="breast_cancer">Breast Cancer Dataset (Diagnostics)</option>
                            <option value="cancer">Cancer Risk Dataset (Prevention)</option>
                            <option value="hybrid_cancer">Hybrid Dataset (Clinical + Lifestyle)</option>
                        </select>
                    </div>
                    <div class="col-md-6 d-flex align-items-end">
                        <p class="text-muted small mb-2 ms-2"><i class="fas fa-info-circle me-1"></i> Sélectionnez le jeu de données pour l'entraînement.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    {% for key, name in models %}
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <span class="fw-bold">{{ name }}</span>
                <i class="fas fa-microchip text-muted opacity-50"></i>
            </div>
            <div class="card-body p-4">
                <p class="text-muted small mb-4">Entraînez le modèle {{ name }} avec les hyperparamètres optimisés.</p>
                
                <div id="results-{{ key }}">
                    <div id="loading-{{ key }}" class="text-center py-4 d-none">
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <p class="text-muted small mb-0">Training in progress...</p>
                    </div>
                </div>

                <div class="d-grid mt-4">
                    <button id="btn-{{ key }}" onclick="trainModel('{{ key }}')" class="btn btn-primary-custom text-white">
                        <i class="fas fa-play me-2"></i> Strat Training
                    </button>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

<script>
function trainModel(model) {
    const dataset = document.getElementById('dataset-select').value;
    const loadingId = `loading-${model}`;
    const resultsId = `results-${model}`;
    const btnId = `btn-${model}`;
    
    document.getElementById(loadingId).classList.remove('d-none');
    document.getElementById(btnId).disabled = true;
    
    fetch(`/train/${model}?dataset=${dataset}`, {
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        document.getElementById(loadingId).classList.add('d-none');
        document.getElementById(btnId).disabled = false;
        displayTrainingResults(resultsId, data);
    })
    .catch(error => {
        document.getElementById(loadingId).classList.add('d-none');
        document.getElementById(btnId).disabled = false;
        document.getElementById(resultsId).innerHTML = '<div class="alert alert-danger small">Training Error</div>';
    });
}

function displayTrainingResults(containerId, data) {
    const container = document.getElementById(containerId);
    let html = '<div class="training-results animate__animated animate__fadeInUp">';
    
    if (data.accuracy !== undefined) {
        html += '<div class="bg-light p-3 rounded-4 mb-3">';
        html += `<div class="d-flex justify-content-between mb-2"><span>Accuracy</span><span class="fw-bold text-success">${(data.accuracy * 100).toFixed(1)}%</span></div>`;
        if (data.f1_score !== undefined) {
            html += `<div class="d-flex justify-content-between mb-2 small text-muted"><span>F1-Score</span><span>${(data.f1_score * 100).toFixed(1)}%</span></div>`;
        }
        if (data.training_time !== undefined) {
            html += `<div class="d-flex justify-content-between small text-muted"><span>Time</span><span>${data.training_time.toFixed(2)}s</span></div>`;
        }
        html += '</div>';
    }
    
    if (data.confusion_matrix) {
        html += '<h6 class="fw-bold extra-small mb-2 text-uppercase text-muted" style="letter-spacing: 1px;">Confusion Matrix</h6>';
        html += '<div class="table-responsive"><table class="table table-sm table-borderless bg-white mb-0 text-center" style="font-size: 0.75rem;">';
        for (const row of data.confusion_matrix) {
            html += '<tr>';
            for (const cell of row) {
                html += `<td class="p-2 border rounded-1 m-1 bg-light fw-bold">${cell}</td>`;
            }
            html += '</tr>';
        }
        html += '</table></div>';
    }
    
    html += '</div>';
    container.innerHTML = html;
}
</script>
{% endblock %}


