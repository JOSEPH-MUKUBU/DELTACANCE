{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<h1 class="mb-4"><i class="fas fa-chart-bar"></i> {{ title }}</h1>

{% if results %}
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>Modèle / Dataset</th>
                    <th>Accuracy</th>
                    <th>Precision</th>
                    <th>Recall</th>
                    <th>F1-Score</th>
                    <th>Temps d'entraînement</th>
                </tr>
            </thead>
            <tbody>
                {% for key, result in results %}
                <tr>
                    <td><strong>{{ key|replace({'_': ' '})|title }}</strong></td>
                    <td>{{ (result.accuracy * 100)|number_format(2) }}%</td>
                    <td>{{ (result.precision * 100)|number_format(2) }}%</td>
                    <td>{{ (result.recall * 100)|number_format(2) }}%</td>
                    <td>{{ (result.f1_score * 100)|number_format(2) }}%</td>
                    <td>{{ result.training_time|number_format(2) }}s</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% else %}
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> Aucun résultat disponible. Veuillez d'abord entraîner les modèles.
    </div>
{% endif %}
{% endblock %}


