{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block breadcrumb %}Analyse Avancée > Validation Croisée{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-random me-2 text-warning"></i>{{ title }}</h2>
        <a href="{{ path('advanced_analysis') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
    </div>
    
    <!-- Model Selector -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center gap-3">
                <strong>Modèle :</strong>
                {% for key, name in models %}
                <a href="{{ path('cross_validation', {'dataset': dataset, 'model': key}) }}" 
                   class="btn {{ model == key ? 'btn-warning' : 'btn-outline-warning' }}">
                    {{ name }}
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
    
    {% if analysis.error is defined %}
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>{{ analysis.error }}
        </div>
    {% elseif analysis.plot is defined %}
        <div class="row">
            <!-- Graph -->
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-chart-bar me-2"></i>Scores par Fold ({{ analysis.cv }}-Fold Cross-Validation)
                    </div>
                    <div class="card-body text-center">
                        <img src="data:image/png;base64,{{ analysis.plot }}" alt="Cross Validation" class="img-fluid">
                    </div>
                </div>
            </div>
            
            <!-- Results Summary -->
            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header bg-warning">
                        <i class="fas fa-chart-line me-2"></i>Résumé des Métriques
                    </div>
                    <div class="card-body">
                        {% for metric, data in analysis.results %}
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <strong>{{ metric|replace({'_': ' '})|title }}</strong>
                                <span class="badge bg-primary">{{ data.mean }}% ± {{ data.std }}%</span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar bg-success" style="width: {{ data.mean }}%"></div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                
                <!-- Info -->
                <div class="card mt-4 bg-light">
                    <div class="card-body">
                        <h6><i class="fas fa-info-circle me-2"></i>K-Fold Cross-Validation</h6>
                        <p class="small text-muted mb-0">
                            Les données sont divisées en {{ analysis.cv }} parties égales. 
                            Chaque partie sert tour à tour de jeu de test, les autres servant à l'entraînement.
                            Cela permet une évaluation plus robuste du modèle.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-circle me-2"></i>Aucune donnée disponible.
        </div>
    {% endif %}
</div>
{% endblock %}
