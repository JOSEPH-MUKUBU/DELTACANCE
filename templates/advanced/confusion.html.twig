{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block breadcrumb %}Analyse Avancée > Matrice de Confusion{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-th me-2 text-info"></i>{{ title }}</h2>
        <a href="{{ path('advanced_analysis') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
    </div>
    
    <!-- Model Selector -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center gap-3">
                <strong>Modèle :</strong>
                {% for key, name in models %}
                <a href="{{ path('confusion_matrix', {'dataset': dataset, 'model': key}) }}" 
                   class="btn {{ model == key ? 'btn-info' : 'btn-outline-info' }}">
                    {{ name }}
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
    
    {% if analysis.error is defined %}
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>{{ analysis.error }}
        </div>
    {% elseif analysis.plot is defined %}
        <div class="row">
            <!-- Graph -->
            <div class="col-lg-7 mb-4">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-th me-2"></i>Matrice de Confusion
                    </div>
                    <div class="card-body text-center">
                        <img src="data:image/png;base64,{{ analysis.plot }}" alt="Confusion Matrix" class="img-fluid" style="max-height: 500px;">
                    </div>
                </div>
            </div>
            
            <!-- Classification Report -->
            <div class="col-lg-5 mb-4">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <i class="fas fa-file-alt me-2"></i>Rapport de Classification
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Classe</th>
                                    <th>Precision</th>
                                    <th>Recall</th>
                                    <th>F1-Score</th>
                                    <th>Support</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for class, metrics in analysis.report %}
                                    {% if class not in ['accuracy', 'macro avg', 'weighted avg'] %}
                                    <tr>
                                        <td><strong>{{ class }}</strong></td>
                                        <td>{{ (metrics.precision * 100)|round(1) }}%</td>
                                        <td>{{ (metrics.recall * 100)|round(1) }}%</td>
                                        <td>{{ (metrics['f1-score'] * 100)|round(1) }}%</td>
                                        <td>{{ metrics.support }}</td>
                                    </tr>
                                    {% endif %}
                                {% endfor %}
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <td><strong>Accuracy</strong></td>
                                    <td colspan="4">{{ (analysis.report.accuracy * 100)|round(2) }}%</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                
                <!-- Interpretation -->
                <div class="card mt-4">
                    <div class="card-header">
                        <i class="fas fa-lightbulb me-2"></i>Interprétation
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">
                            La matrice de confusion montre les prédictions du modèle (colonnes) vs les vraies valeurs (lignes).
                        </p>
                        <ul class="small">
                            <li><strong>Diagonale :</strong> Prédictions correctes</li>
                            <li><strong>Hors diagonale :</strong> Erreurs de classification</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-circle me-2"></i>Aucune donnée disponible.
        </div>
    {% endif %}
</div>
{% endblock %}
