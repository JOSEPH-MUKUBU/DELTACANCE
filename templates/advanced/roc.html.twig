{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block breadcrumb %}Analyse Avancée > Courbes ROC{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-chart-area me-2 text-success"></i>{{ title }}</h2>
        <a href="{{ path('advanced_analysis') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
    </div>
    
    <!-- Model Selector -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center gap-3">
                <strong>Modèle :</strong>
                {% for key, name in models %}
                <a href="{{ path('roc_curves', {'dataset': dataset, 'model': key}) }}" 
                   class="btn {{ model == key ? 'btn-primary' : 'btn-outline-primary' }}">
                    {{ name }}
                </a>
                {% endfor %}
            </div>
        </div>
    </div>
    
    {% if analysis.error is defined %}
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>{{ analysis.error }}
        </div>
    {% elseif analysis.plot is defined %}
        <div class="row">
            <!-- Graph -->
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-chart-line me-2"></i>Courbes ROC (Receiver Operating Characteristic)
                    </div>
                    <div class="card-body text-center">
                        <img src="data:image/png;base64,{{ analysis.plot }}" alt="ROC Curves" class="img-fluid" style="max-height: 600px;">
                    </div>
                </div>
            </div>
            
            <!-- AUC Scores -->
            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <i class="fas fa-percentage me-2"></i>Scores AUC
                    </div>
                    <div class="card-body">
                        {% for class, score in analysis.auc_scores %}
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><strong>{{ class }}</strong></span>
                                <span class="badge {{ score >= 0.9 ? 'bg-success' : (score >= 0.7 ? 'bg-warning' : 'bg-danger') }}">
                                    {{ score }}
                                </span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar {{ score >= 0.9 ? 'bg-success' : (score >= 0.7 ? 'bg-warning' : 'bg-danger') }}" 
                                     style="width: {{ score * 100 }}%"></div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
                
                <!-- Interpretation Help -->
                <div class="card mt-4">
                    <div class="card-header">
                        <i class="fas fa-lightbulb me-2"></i>Interprétation
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <span class="badge bg-success">0.9 - 1.0</span> Excellent
                            </li>
                            <li class="mb-2">
                                <span class="badge bg-warning">0.7 - 0.9</span> Bon
                            </li>
                            <li class="mb-2">
                                <span class="badge bg-danger">&lt; 0.7</span> À améliorer
                            </li>
                            <li class="mt-3 text-muted small">
                                <i class="fas fa-info-circle me-1"></i>
                                Un AUC de 0.5 correspond à un classificateur aléatoire.
                            </li>
                        </ul>
                    </div>
                </div>
                
                <!-- Info -->
                <div class="card mt-4 bg-light">
                    <div class="card-body">
                        <p class="mb-2"><strong>Dataset :</strong> {{ dataset|replace({'_': ' '})|title }}</p>
                        <p class="mb-2"><strong>Modèle :</strong> {{ model|replace({'_': ' '})|title }}</p>
                        <p class="mb-0"><strong>Classes :</strong> {{ analysis.n_classes }}</p>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-circle me-2"></i>Aucune donnée disponible. Veuillez d'abord entraîner les modèles.
        </div>
    {% endif %}
</div>
{% endblock %}
