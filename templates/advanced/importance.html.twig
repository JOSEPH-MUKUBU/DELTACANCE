{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block breadcrumb %}Analyse Avancée > Feature Importance{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-sort-amount-down me-2 text-primary"></i>{{ title }}</h2>
        <a href="{{ path('advanced_analysis') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
    </div>
    
    {% if analysis.error is defined %}
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle me-2"></i>{{ analysis.error }}
        </div>
    {% elseif analysis.plot is defined %}
        <div class="row">
            <!-- Graph -->
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-chart-bar me-2"></i>Graphique d'Importance des Features
                    </div>
                    <div class="card-body text-center">
                        <img src="data:image/png;base64,{{ analysis.plot }}" alt="Feature Importance" class="img-fluid" style="max-height: 600px;">
                    </div>
                </div>
            </div>
            
            <!-- Data Table -->
            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header">
                        <i class="fas fa-list-ol me-2"></i>Classement des Features
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Feature</th>
                                    <th>Importance</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in analysis.data %}
                                <tr>
                                    <td>{{ loop.index }}</td>
                                    <td>{{ item.feature }}</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1 me-2" style="height: 8px;">
                                                <div class="progress-bar bg-primary" style="width: {{ item.importance }}%"></div>
                                            </div>
                                            <span class="badge bg-primary">{{ item.importance }}%</span>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                
                <!-- Top Features -->
                <div class="card mt-4">
                    <div class="card-header bg-success text-white">
                        <i class="fas fa-star me-2"></i>Top 5 Features
                    </div>
                    <div class="card-body">
                        <ol>
                            {% for feature in analysis.top_features %}
                            <li><strong>{{ feature }}</strong></li>
                            {% endfor %}
                        </ol>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-circle me-2"></i>Aucune donnée disponible. Veuillez d'abord exécuter le preprocessing.
        </div>
    {% endif %}
</div>
{% endblock %}
