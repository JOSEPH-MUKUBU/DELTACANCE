{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% block breadcrumb %}Model Comparison{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <span class="fw-bold"><i class="fas fa-balance-scale me-2"></i> Performance Matrix</span>
                <span class="badge rounded-pill bg-light text-muted border">Metrics Comparison</span>
            </div>
            <div class="card-body p-0">
                <div id="comparison-results">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <p class="text-muted">Loading model benchmarks...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header py-3">
                <span class="fw-bold"><i class="fas fa-chart-bar me-2"></i> Visualization Benchmarks</span>
            </div>
            <div class="card-body p-4">
                <div style="height: 350px;">
                    <canvas id="comparisonChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Charger les résultats depuis le serveur
fetch('/results', {
    headers: {
        'X-Requested-With': 'XMLHttpRequest'
    }
})
    .then(response => {
        if (!response.ok) throw new Error('Not found');
        return response.json();
    })
    .then(data => {
        if (data && Object.keys(data).length > 0) {
            displayComparison(data);
        } else {
            document.getElementById('comparison-results').innerHTML = 
                '<div class="text-center py-5"><i class="fas fa-layer-group fa-3x text-primary mb-3 opacity-25"></i><h5 class="fw-bold">No Records Found</h5><p class="text-muted small">Please train at least one model in the <b>Modeling / Training</b> section to see comparisons.</p></div>';
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        document.getElementById('comparison-results').innerHTML = '<div class="alert alert-danger m-4 small"><i class="fas fa-exclamation-circle me-2"></i>Failed to fetch performance data. Please ensure models are trained.</div>';
    });

function displayComparison(results) {
    const models = Object.keys(results);
    const metrics = ['accuracy', 'precision', 'recall', 'f1_score'];
    const colors = ['#4dabf7', '#fcc419', '#38d9a9', '#ff6b6b'];
    
    let html = '<div class="table-responsive"><table class="table table-hover align-middle mb-0">';
    html += '<thead class="bg-light"><tr><th class="ps-4 border-0 py-3" style="font-size: 0.8rem; text-transform: uppercase; color: #adb5bd;">Model Name</th>';
    metrics.forEach(m => {
        html += `<th class="border-0 py-3 text-center" style="font-size: 0.8rem; text-transform: uppercase; color: #adb5bd;">${m.replace('_', ' ')}</th>`;
    });
    html += '</tr></thead><tbody>';
    
    models.forEach(model => {
        const r = results[model];
        html += '<tr>';
        html += `<td class="ps-4 py-3"><div class="d-flex align-items-center"><div class="rounded-circle me-3" style="width: 10px; height: 10px; background-color: var(--primary-accent);"></div><span class="fw-bold text-dark">${model}</span></div></td>`;
        metrics.forEach((m, idx) => {
            const val = r[m] || 0;
            const valueDisplay = (val * 100).toFixed(1) + '%';
            html += `<td class="text-center py-3"><span class="badge rounded-pill px-3 py-2" style="background-color: ${colors[idx]}15; color: ${colors[idx]}; font-weight: 600;">${valueDisplay}</span></td>`;
        });
        html += '</tr>';
    });
    html += '</tbody></table></div>';
    
    document.getElementById('comparison-results').innerHTML = html;
    
    // Graphique Chart.js
    const ctx = document.getElementById('comparisonChart').getContext('2d');
    const datasets = metrics.map((metric, idx) => ({
        label: metric.replace('_', ' ').toUpperCase(),
        data: models.map(model => results[model][metric] * 100 || 0),
        backgroundColor: colors[idx] + 'cc',
        borderColor: colors[idx],
        borderWidth: 0,
        borderRadius: 4,
        barPercentage: 0.6,
        categoryPercentage: 0.7
    }));
    
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: models,
            datasets: datasets
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                    align: 'end',
                    labels: { boxWidth: 10, usePointStyle: true, padding: 20, font: { family: "'Inter', sans-serif", size: 11 } }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    max: 100,
                    grid: { borderDash: [5, 5], color: '#f1f3f5' },
                    ticks: {
                        font: { size: 10 },
                        callback: function(value) { return value + '%'; }
                    }
                },
                x: {
                    grid: { display: false },
                    ticks: { font: { size: 11, weight: 'bold' } }
                }
            }
        }
    });
}
</script>
{% endblock %}


