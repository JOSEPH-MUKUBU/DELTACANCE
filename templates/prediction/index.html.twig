{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% block breadcrumb %}Predictive Analysis{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center py-3">
                <span class="fw-bold"><i class="fas fa-stethoscope me-2"></i> Patient Information</span>
                <span class="badge rounded-pill bg-light text-primary border">Diagnostic Form</span>
            </div>
            <div class="card-body p-4">
                <form method="POST" action="{{ path('prediction') }}">
                    <div class="mb-4">
                        <label for="dataset" class="form-label fw-semibold" style="font-size: 0.85rem; color: #495057;">Select Analysis Model</label>
                        <select name="dataset" id="dataset" class="form-select border-0 bg-light rounded-3 py-2" required>
                            <option value="breast_cancer">Breast Cancer Diagnostic</option>
                            <option value="cancer">General Cancer Risk Assessment</option>
                            <option value="hybrid_cancer">Hybrid Dataset (Clinical + Lifestyle)</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label for="model" class="form-label fw-semibold" style="font-size: 0.85rem; color: #495057;">Select ML Algorithm</label>
                        <select name="model" id="model" class="form-select border-0 bg-light rounded-3 py-2" required>
                            <option value="">-- Select Algorithm --</option>
                            <option value="random_forest">Random Forest (Recommended)</option>
                            <option value="svm">Support Vector Machine (SVM)</option>
                            <option value="neural_network">Neural Network</option>
                        </select>
                    </div>
                    
                    <hr class="my-4 opacity-5">

                    <div id="breast-cancer-form">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="age" class="form-label" style="font-size: 0.8rem;">Patient Age</label>
                                <input type="number" class="form-control bg-light border-0 py-2" name="age" id="age" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="grade" class="form-label" style="font-size: 0.8rem;">Tumor Grade (1-3)</label>
                                <input type="number" class="form-control bg-light border-0 py-2" name="grade" id="grade" min="1" max="3" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="tumor_size" class="form-label" style="font-size: 0.8rem;">Tumor Size (mm)</label>
                                <input type="number" class="form-control bg-light border-0 py-2" name="tumor_size" id="tumor_size" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="estrogen_status" class="form-label" style="font-size: 0.8rem;">Estrogen Status</label>
                                <select name="estrogen_status" id="estrogen_status" class="form-select bg-light border-0 py-2" required>
                                    <option value="Positive">Positive</option>
                                    <option value="Negative">Negative</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div id="cancer-form" style="display:none;">
                        <div class="row">
                            <div class="col-md-6 mb-3" id="gender-field">
                                <label for="gender" class="form-label" style="font-size: 0.8rem;">Gender</label>
                                <select name="gender" id="gender" class="form-select bg-light border-0 py-2" required>
                                    <option value="">-- Select --</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="obesity" class="form-label" style="font-size: 0.8rem;">Obesity Class</label>
                                <select name="obesity" id="obesity" class="form-select bg-light border-0 py-2" required>
                                    <option value="">-- Select --</option>
                                    <option value="Poids normal Surpoids">Normal / Overweight</option>
                                    <option value="Obésité de classe I">Class I Obesity</option>
                                    <option value="Obésité de classe II">Class II Obesity</option>
                                    <option value="Obésité de classe III">Class III Obesity</option>
                                    <option value="Obesité exteme">Extreme Obesity</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="smoking" class="form-label" style="font-size: 0.8rem;">Active Smoking</label>
                                <select name="smoking" id="smoking" class="form-select bg-light border-0 py-2" required>
                                    <option value="">-- Select --</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="genetic_risk" class="form-label" style="font-size: 0.8rem;">Genetic Risk</label>
                                <select name="genetic_risk" id="genetic_risk" class="form-select bg-light border-0 py-2" required>
                                    <option value="">-- Select --</option>
                                    <option value="Yes">Yes</option>
                                    <option value="No">No</option>
                                    <option value="Maybe">Maybe</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary-custom text-white py-2">
                            <i class="fas fa-magic me-2"></i> Run AI Prediction
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-5">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header py-3">
                <span class="fw-bold"><i class="fas fa-microscope me-2"></i> Prediction Analysis</span>
            </div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                {% if prediction %}
                    {% if prediction.error is defined %}
                        <div class="alert alert-danger m-4 small">
                            <i class="fas fa-exclamation-circle me-2"></i> {{ prediction.error }}
                        </div>
                    {% else %}
                        <div class="text-center animate__animated animate__zoomIn">
                            <div class="rounded-pill px-4 py-2 mb-4 d-inline-block" style="background-color: {% if prediction.prediction == 'Alive' or prediction.prediction == 'Low' or prediction.prediction == 'Normal' %}#e6fcf5{% else %}#fff5f5{% endif %}; border: 1px solid {% if prediction.prediction == 'Alive' or prediction.prediction == 'Low' or prediction.prediction == 'Normal' %}#38d9a9{% else %}#ff6b6b{% endif %};">
                                <span class="fw-bold" style="color: {% if prediction.prediction == 'Alive' or prediction.prediction == 'Low' or prediction.prediction == 'Normal' %}#38d9a9{% else %}#ff6b6b{% endif %}; text-transform: uppercase; font-size: 0.75rem;">Summary Result</span>
                            </div>
                            <h2 class="display-5 fw-bold mb-2">{{ prediction.prediction|default('N/A') }}</h2>
                            <p class="text-muted mb-4">Patient Prognosis / Risk Level</p>

                        {% if prediction.probability is defined %}
                        <div class="position-relative d-inline-block mb-4">
                            <svg width="150" height="150" viewBox="0 0 150 150">
                                <circle cx="75" cy="75" r="65" fill="none" stroke="#f1f3f5" stroke-width="12"></circle>
                                <circle cx="75" cy="75" r="65" fill="none" stroke="var(--primary-accent)" stroke-width="12" stroke-dasharray="{{ (prediction.probability * 408.4)|number_format(0, '.', '') }} 408.4" stroke-dashoffset="0" transform="rotate(-90 75 75)" style="transition: stroke-dasharray 1s ease-out;"></circle>
                                <text x="75" y="82" text-anchor="middle" font-size="24" font-weight="700" fill="#495057">{{ (prediction.probability * 100)|number_format(1) }}%</text>
                            </svg>
                            <div class="mt-2 fw-bold text-primary" style="font-size: 0.8rem;">Model Confidence</div>
                        </div>
                        {% endif %}

                        {% if prediction.suggestion is defined %}
                        <div class="alert alert-{{ prediction.suggestion.bg_class }} mt-2 border-{{ prediction.suggestion.bg_class }} border opacity-90 rounded-4 shadow-sm text-start w-100">
                            <div class="d-flex align-items-center">
                                <div class="me-3">
                                    <div class="p-2 bg-white rounded-circle text-{{ prediction.suggestion.bg_class }} d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                        <i class="fas {{ prediction.suggestion.icon }} fa-lg"></i>
                                    </div>
                                </div>
                                <div>
                                    <h6 class="fw-bold alert-heading mb-1 text-dark" style="font-size: 0.9rem;">{{ prediction.suggestion.title }}</h6>
                                    <p class="mb-0 small text-muted" style="line-height: 1.4;">{{ prediction.suggestion.text }}</p>
                                </div>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                    {% endif %}
                {% else %}
                    <div class="text-center py-5 opacity-25">
                        <i class="fas fa-brain fa-6x mb-4 text-muted"></i>
                        <h5>No Data Analyzed</h5>
                        <p class="text-muted small">Fill the form to run the prediction model</p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
function toggleRequired(containerId, isRequired) {
    const container = document.getElementById(containerId);
    const inputs = container.querySelectorAll('input, select');
    inputs.forEach(input => {
        if (isRequired) {
            input.setAttribute('required', 'required');
        } else {
            input.removeAttribute('required');
        }
    });
}

document.getElementById('dataset').addEventListener('change', function() {
    const dataset = this.value;
    const breastForm = document.getElementById('breast-cancer-form');
    const cancerForm = document.getElementById('cancer-form');
    const genderField = document.getElementById('gender-field');
    
    if (dataset === 'breast_cancer') {
        breastForm.style.display = 'block';
        cancerForm.style.display = 'none';
        breastForm.classList.add('animate__animated', 'animate__fadeIn');
        toggleRequired('breast-cancer-form', true);
        toggleRequired('cancer-form', false);
    } else if (dataset === 'hybrid_cancer') {
        // Mode Hybride : Affiche les deux formulaires pertinent
        breastForm.style.display = 'block';
        cancerForm.style.display = 'block';
        
        // Cache le genre car non pertinent pour le dataset clinique (généralement féminin)
        genderField.style.display = 'none';
        document.getElementById('gender').removeAttribute('required');
        
        breastForm.classList.add('animate__animated', 'animate__fadeIn');
        cancerForm.classList.add('animate__animated', 'animate__fadeIn');
        
        toggleRequired('breast-cancer-form', true);
        
        // Active requis uniquement pour les champs visibles de cancer-form
        document.getElementById('obesity').setAttribute('required', 'required');
        document.getElementById('smoking').setAttribute('required', 'required');
        document.getElementById('genetic_risk').setAttribute('required', 'required');
        
    } else {
        breastForm.style.display = 'none';
        cancerForm.style.display = 'block';
        genderField.style.display = 'block';
        
        cancerForm.classList.add('animate__animated', 'animate__fadeIn');
        toggleRequired('breast-cancer-form', false);
        toggleRequired('cancer-form', true);
    }
});

// Initial state check
window.addEventListener('DOMContentLoaded', (event) => {
    const dataset = document.getElementById('dataset').value;
    const breastForm = document.getElementById('breast-cancer-form');
    const cancerForm = document.getElementById('cancer-form');
    
    if (dataset === 'breast_cancer') {
        toggleRequired('breast-cancer-form', true);
        toggleRequired('cancer-form', false);
    } else if (dataset === 'hybrid_cancer') {
        breastForm.style.display = 'block';
        cancerForm.style.display = 'block';
        document.getElementById('gender-field').style.display = 'none';
        document.getElementById('gender').removeAttribute('required');
        toggleRequired('breast-cancer-form', true);
        document.getElementById('obesity').setAttribute('required', 'required');
        document.getElementById('smoking').setAttribute('required', 'required');
        document.getElementById('genetic_risk').setAttribute('required', 'required');
    } else {
        toggleRequired('breast-cancer-form', false);
        toggleRequired('cancer-form', true);
    }
});
</script>
{% endblock %}


